# Taiwan Strait EWS — Environment Variables
#
# Copy to .env and fill in values. The real .env is gitignored.
#
# For GitHub Actions deployment, copy each value into a GitHub Secret or
# Variable with the name shown in [brackets] at the end of each line.

# ---------- RUNTIME (read by collectors / alerting.py) ----------

# Slack incoming webhook URL                                    [GH secret: TAIWAN_ALERT_SLACK_WEBHOOK]
TAIWAN_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../...

# Apify API token                                               [GH secret: APIFY_API_TOKEN]
APIFY_API_TOKEN=apify_api_...

# Apify cost cap per run in USD                                 [GH var: APIFY_MAX_CHARGE_USD]
APIFY_MAX_CHARGE_USD=0.50

# Cloudflare Radar API token — read-only scope                  [GH secret: CF_RADAR_TOKEN]
# Used by collectors/cyber_infra.py. CLOUDFLARE_API_TOKEN is the name
# the Python code reads; the workflow sets it from CF_RADAR_TOKEN so
# local and CI behave the same.
CLOUDFLARE_API_TOKEN=
CF_RADAR_TOKEN=

# NOTAM service — optional                                      [GH secret: NOTAM_API_URL / NOTAM_API_TOKEN]
# Examples:
#   Notamify:  https://api.notamify.com/v1/notam?icao={locations}
#   ICAO:      https://applications.icao.int/dataservices/api/notams-public?api_key=KEY&locations={locations}&format=json
NOTAM_API_URL=
NOTAM_API_TOKEN=

# Alert promotion threshold (default 2)                         [GH var: TAIWAN_ALERT_THRESHOLD]
#   1 = hair-trigger; any single primary escalates to RED
#   2 = original gated behavior (1 primary + 1 other = AMBER)
#   3 = dampened; requires more convergence before promoting
TAIWAN_ALERT_THRESHOLD=2


# ---------- DEPLOYMENT (GitHub Actions → Cloudflare Pages) ----------

# Cloudflare Pages deploy token — Pages:Edit scope              [GH secret: CF_PAGES_TOKEN]
# Create at: dash.cloudflare.com → My Profile → API Tokens → Create Token
# Permissions required:
#   Account → Cloudflare Pages → Edit
#   User → Memberships → Read
# Keep SEPARATE from CF_RADAR_TOKEN so a collector-token leak cannot
# mutate the deployed site.
CF_PAGES_TOKEN=

# Cloudflare Account ID (for wrangler pages deploy)             [GH secret: CLOUDFLARE_ACCOUNT_ID]
# Find in: dash.cloudflare.com → any domain → right sidebar → "Account ID"
CLOUDFLARE_ACCOUNT_ID=

# GitHub repo URL where this project is pushed (for reference, not read by code)
GITHUB_REPO=
